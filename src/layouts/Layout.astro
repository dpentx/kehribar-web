---
import '../styles/global.css';
import { ClientRouter } from 'astro:transitions';
import Icon from '../components/Icon.astro';
import { NAV_ITEMS, translations, langPath, type Lang } from '../lib/i18n';

interface Props {
  title?: string;
  description?: string;
  lang?: Lang;
  activePage?: string;
}

const {
  title = 'Kehribar — dpentx',
  description = 'Kehribar (dpentx) — NixOS, açık kaynak ve çeviri projeleri üzerine kişisel site.',
  lang = 'tr',
  activePage = 'home',
} = Astro.props;

const avatarUrl = 'https://github.com/dpentx.png?size=200'; // stable, doesn't depend on any build-time API call succeeding

const dict = translations[lang];
const currentNavItem = NAV_ITEMS.find((i) => i.page === activePage) ?? NAV_ITEMS[0];
const trHref = langPath('tr', currentNavItem.href);
const enHref = langPath('en', currentNavItem.href);
const rssUrl = langPath(lang, '/rss.xml');

// The rail persists its DOM across navigations (see transition:persist
// below), so a language switch won't naturally re-render its text. This
// gives the client script both languages' labels to swap in after a
// TR<->EN navigation.
const railLabels = {
    tr: { nav: NAV_ITEMS.map((i) => ({ page: i.page, label: translations.tr[i.key] })), navAria: 'Ana navigasyon', search: translations.tr['cmdk-placeholder'], empty: translations.tr['cmdk-empty'] },
    en: { nav: NAV_ITEMS.map((i) => ({ page: i.page, label: translations.en[i.key] })), navAria: 'Main navigation', search: translations.en['cmdk-placeholder'], empty: translations.en['cmdk-empty'] },
};
---

<!DOCTYPE html>
<html lang={lang}>
<head>
    <script is:inline>
        // Runs synchronously, before first paint, so there's no flash of the
        // "wrong" theme or language.
        (function () {
            // ---- theme: default to true-black when the OS/Android theme
            // is dark and the person hasn't chosen a preference yet ----
            try {
                var savedTheme = localStorage.getItem('trueBlack');
                var wantsTrueBlack = savedTheme === '1' ||
                    (savedTheme === null && window.matchMedia && window.matchMedia('(prefers-color-scheme: dark)').matches);
                if (wantsTrueBlack) document.documentElement.classList.add('true-black');
            } catch (_) {}

            // ---- language: redirect to /en on first visit if the
            // phone/browser language isn't Turkish. Only ever runs once —
            // after that, `preferredLanguage` is set and this is a no-op. ----
            try {
                var pref = localStorage.getItem('preferredLanguage');
                if (!pref) {
                    var path = location.pathname;
                    var isEnglish = path === '/en' || path.indexOf('/en/') === 0;
                    var browserLang = (navigator.language || navigator.userLanguage || 'tr').toLowerCase();
                    var wantsEnglish = browserLang.indexOf('tr') !== 0;
                    if (wantsEnglish && !isEnglish) {
                        var target = path === '/' ? '/en' : '/en' + path;
                        localStorage.setItem('preferredLanguage', 'en');
                        location.replace(target + location.search + location.hash);
                    } else {
                        // Nothing to redirect (already correct, or Turkish
                        // preferred) — still remember it so we never check again.
                        localStorage.setItem('preferredLanguage', wantsEnglish ? 'en' : 'tr');
                    }
                }
            } catch (_) {}
        })();
    </script>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{title}</title>
    <meta name="description" content={description}>
    <link rel="icon" href="https://github.com/dpentx.png?size=64" type="image/png">
    <link rel="alternate" type="application/rss+xml" title="Kehribar Blog" href={rssUrl}>

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link rel="preconnect" href="https://avatars.githubusercontent.com" crossorigin>
    <link rel="dns-prefetch" href="https://api.github.com">
    <link
        rel="preload"
        as="style"
        href="https://fonts.googleapis.com/css2?family=Source+Serif+4:opsz,wght@8..60,400;8..60,600;8..60,700&family=Source+Sans+3:wght@400;500;600&family=IBM+Plex+Mono:wght@400;500;600&display=swap"
        onload="this.onload=null;this.rel='stylesheet'"
    >
    <noscript>
        <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Source+Serif+4:opsz,wght@8..60,400;8..60,600;8..60,700&family=Source+Sans+3:wght@400;500;600&family=IBM+Plex+Mono:wght@400;500;600&display=swap">
    </noscript>
    <ClientRouter />
    <!-- No Tailwind, no Font Awesome CDN: icons are inlined SVG (see
         src/components/Icon.astro), custom CSS only. -->
</head>
<body>
    <div class="lang-switcher" transition:persist="lang-switcher">
        <a href={rssUrl} class="lang-btn" id="rss-link" title="RSS" aria-label="RSS feed">
            <Icon name="rss" class="icon" />
        </a>
        <a class:list={["lang-btn", { active: lang === 'tr' }]} href={trHref} id="lang-tr-link" data-lang-link="tr">TR</a>
        <a class:list={["lang-btn", { active: lang === 'en' }]} href={enHref} id="lang-en-link" data-lang-link="en">EN</a>
    </div>

    <div class="shell">
        <aside class="rail" transition:persist="rail">
            <div class="rail-id">
                <img class="avatar" src={avatarUrl} alt="Avatar" loading="eager" width="56" height="56">
                <div>
                    <div class="rail-name">Kehribar</div>
                    <div class="rail-handle">@dpentx</div>
                </div>
            </div>

            <nav class="rail-nav" id="rail-nav" aria-label="Ana navigasyon">
                {NAV_ITEMS.map((item) => (
                    <a
                        class:list={["rail-link", { active: activePage === item.page }]}
                        href={langPath(lang, item.href)}
                        data-page={item.page}
                        data-href={item.href}
                    >
                        <span class="dot">·</span>
                        <Icon name={item.icon} class="icon" />
                        <span class="label">{dict[item.key]}</span>
                    </a>
                ))}
            </nav>

            <div class="rail-tools">
                <button class="rail-btn" id="cmdk-trigger" aria-label={dict['cmdk-placeholder']}>
                    <Icon name="magnifying-glass" class="icon" />
                    <span>/</span>
                </button>
                <button class="rail-btn" id="theme-toggle" aria-label="True Black">
                    <Icon name="circle-half-stroke" class="icon" />
                    <span>{dict['theme-label']}</span>
                </button>
            </div>
        </aside>

        <main>
            <slot />
        </main>
    </div>

    <!-- command palette -->
    <div class="cmdk-backdrop" id="cmdk-backdrop" transition:persist="cmdk">
        <div class="cmdk-panel" role="dialog" aria-modal="true" aria-label={dict['cmdk-placeholder']}>
            <input class="cmdk-input" id="cmdk-input" type="text" placeholder={dict['cmdk-placeholder']} autocomplete="off" spellcheck="false">
            <div class="cmdk-list" id="cmdk-list"></div>
            <div class="cmdk-hint">
                <span><kbd>↑↓</kbd> {dict['cmdk-hint-nav']}</span>
                <span><kbd>↵</kbd> {dict['cmdk-hint-select']}</span>
                <span><kbd>esc</kbd> {dict['cmdk-hint-close']}</span>
            </div>
        </div>
    </div>

    <!-- KAIDEN_BREAK EASTER EGG -->
    <div id="kaiden-overlay" onclick="this.classList.remove('show')">
        <svg class="kaiden-cat" width="260" height="220" viewBox="0 0 260 220" xmlns="http://www.w3.org/2000/svg">
            <ellipse cx="130" cy="190" rx="95" ry="14" fill="#000" opacity="0.25"/>
            <path d="M70 80 Q40 30 60 35 Q85 40 90 70 Z" fill="#e69875"/>
            <path d="M190 80 Q220 30 200 35 Q175 40 170 70 Z" fill="#e69875"/>
            <path d="M78 78 Q58 45 70 48 Q86 52 88 70 Z" fill="#16130f"/>
            <path d="M182 78 Q202 45 190 48 Q174 52 172 70 Z" fill="#16130f"/>
            <ellipse cx="130" cy="130" rx="92" ry="78" fill="#e69875"/>
            <ellipse cx="130" cy="150" rx="55" ry="45" fill="#f3d9bd"/>
            <circle cx="98" cy="118" r="11" fill="#16130f"/>
            <circle cx="162" cy="118" r="11" fill="#16130f"/>
            <circle cx="101" cy="114" r="3" fill="#fff"/>
            <circle cx="165" cy="114" r="3" fill="#fff"/>
            <path d="M122 138 Q130 145 138 138 Q134 148 130 148 Q126 148 122 138Z" fill="#d97757"/>
            <path d="M130 146 Q120 158 105 154" stroke="#16130f" stroke-width="2.5" fill="none" stroke-linecap="round"/>
            <path d="M130 146 Q140 158 155 154" stroke="#16130f" stroke-width="2.5" fill="none" stroke-linecap="round"/>
            <line x1="70" y1="128" x2="40" y2="122" stroke="#16130f" stroke-width="1.5"/>
            <line x1="70" y1="136" x2="38" y2="136" stroke="#16130f" stroke-width="1.5"/>
            <line x1="190" y1="128" x2="220" y2="122" stroke="#16130f" stroke-width="1.5"/>
            <line x1="190" y1="136" x2="222" y2="136" stroke="#16130f" stroke-width="1.5"/>
            <ellipse cx="100" cy="195" rx="20" ry="13" fill="#e69875"/>
            <ellipse cx="160" cy="195" rx="20" ry="13" fill="#e69875"/>
            <path d="M205 150 Q250 140 245 95 Q243 75 225 80" stroke="#e69875" stroke-width="16" fill="none" stroke-linecap="round"/>
        </svg>
        <div class="kaiden-caption">🐾 Kaiden Break! Biraz mola ver 🐾</div>
    </div>

    <script define:vars={{ railLabels }}>
        // IMPORTANT: this script tag is NOT guaranteed to re-execute on
        // every soft navigation — if you return to a page whose script
        // content is byte-identical to one already run, the browser/router
        // may skip re-running it. So anything that needs to happen on
        // EVERY navigation (including returning to a previously-visited
        // page) must live inside an 'astro:page-load' listener, which
        // Astro guarantees fires every time. Anything that must only ever
        // run ONCE (attaching a `document`-level listener) goes behind the
        // window.__kehribarInit guard below instead.
        window.__kehribarRailLabels = railLabels;

        // Keep the persisted rail (and lang-switcher) in sync with the
        // current page after every navigation. Both persist their DOM
        // nodes across navigations (see transition:persist above) to avoid
        // a flash/flicker of a full re-render, which means none of their
        // attributes — text, href, active-state — get refreshed by the
        // server automatically. This derives all of it from the current
        // URL/lang instead, so it's correct regardless of which page
        // originally rendered the persisted markup.
        function kehribarLangPath(lang, path) {
            if (lang !== 'en') return path;
            return path === '/' ? '/en' : '/en' + path;
        }

        function kehribarSyncRail() {
            const lang = document.documentElement.lang === 'en' ? 'en' : 'tr';
            const labels = window.__kehribarRailLabels[lang];
            const path = location.pathname;

            document.querySelectorAll('.rail-link').forEach((el) => {
                const baseHref = el.dataset.href; // lang-agnostic, e.g. "/blog" or "/"
                const label = labels.nav.find((n) => n.page === el.dataset.page);
                const span = el.querySelector('.label');
                if (label && span) span.textContent = label.label;

                const newHref = kehribarLangPath(lang, baseHref);
                el.setAttribute('href', newHref);

                const isHome = baseHref === '/';
                const active = isHome ? path === newHref : (path === newHref || path.startsWith(newHref + '/'));
                el.classList.toggle('active', active);
            });

            const railNav = document.getElementById('rail-nav');
            if (railNav) railNav.setAttribute('aria-label', labels.navAria);
            const cmdkTrigger = document.getElementById('cmdk-trigger');
            if (cmdkTrigger) cmdkTrigger.setAttribute('aria-label', labels.search);
            const cmdkInput = document.getElementById('cmdk-input');
            if (cmdkInput) cmdkInput.setAttribute('placeholder', labels.search);

            // lang-switcher: recompute TR/EN/RSS targets from the current
            // page's language-agnostic base path.
            const isEnglish = path === '/en' || path.startsWith('/en/');
            const basePath = isEnglish ? (path.slice(3) || '/') : path;
            const trLink = document.getElementById('lang-tr-link');
            const enLink = document.getElementById('lang-en-link');
            const rssLink = document.getElementById('rss-link');
            if (trLink) { trLink.setAttribute('href', basePath); trLink.classList.toggle('active', lang === 'tr'); }
            if (enLink) { enLink.setAttribute('href', kehribarLangPath('en', basePath)); enLink.classList.toggle('active', lang === 'en'); }
            if (rssLink) rssLink.setAttribute('href', kehribarLangPath(lang, '/rss.xml'));
        }
        kehribarSyncRail();
        document.addEventListener('astro:page-load', kehribarSyncRail);

        if (window.__kehribarInit) {
            // Global listeners already attached on a previous page load —
            // nothing further to do this navigation.
        } else {
        window.__kehribarInit = true;
        // ---------- theme + lang preference (event delegation, attached
        // once on `document` — safe across every View Transitions swap) ----------
        (function () {
            // The class is already set on <html> by the blocking head
            // script (before first paint); nothing to do here on init.

            document.addEventListener('click', (e) => {
                const target = e.target;
                const themeBtn = target.closest('#theme-toggle');
                if (themeBtn) {
                    document.documentElement.classList.toggle('true-black');
                    localStorage.setItem('trueBlack', document.documentElement.classList.contains('true-black') ? '1' : '0');
                    return;
                }
                const langLink = target.closest('[data-lang-link]');
                if (langLink) {
                    const lang = langLink.getAttribute('data-lang-link');
                    if (lang) localStorage.setItem('preferredLanguage', lang);
                }
            });

            document.addEventListener('astro:after-swap', () => {
                if (localStorage.getItem('trueBlack') === '1') document.documentElement.classList.add('true-black');
            });
        })();

        // ---------- command palette ----------
        (function () {
            const backdrop = document.getElementById('cmdk-backdrop');
            const input = document.getElementById('cmdk-input');
            const list = document.getElementById('cmdk-list');
            const trigger = document.getElementById('cmdk-trigger');
            if (!backdrop || !input || !list) return;

            let items = null; // lazy-loaded search index
            let cachedUrl = null;
            let activeIndex = 0;

            function currentLang() {
                return document.documentElement.lang === 'en' ? 'en' : 'tr';
            }

            async function ensureItems() {
                const lang = currentLang();
                const url = lang === 'en' ? '/en/search-index.json' : '/search-index.json';
                if (items && cachedUrl === url) return items;
                try {
                    const res = await fetch(url);
                    items = await res.json();
                    cachedUrl = url;
                } catch {
                    items = [];
                }
                return items;
            }

            function render(filtered) {
                list.innerHTML = '';
                if (filtered.length === 0) {
                    const empty = document.createElement('div');
                    empty.className = 'cmdk-empty';
                    empty.textContent = window.__kehribarRailLabels[currentLang()].empty;
                    list.appendChild(empty);
                    return;
                }
                filtered.forEach((it, i) => {
                    const a = document.createElement('a');
                    a.href = it.url;
                    a.className = 'cmdk-item';
                    a.dataset.active = i === activeIndex ? 'true' : 'false';
                    a.innerHTML = `<span>${it.title}</span>`;
                    list.appendChild(a);
                });
            }

            async function open() {
                backdrop.classList.add('show');
                input.value = '';
                input.focus();
                activeIndex = 0;
                const all = await ensureItems();
                render(all);
            }

            function close() {
                backdrop.classList.remove('show');
            }

            trigger?.addEventListener('click', open);

            document.addEventListener('keydown', (e) => {
                const tag = (e.target && e.target.tagName) || '';
                const typing = tag === 'INPUT' || tag === 'TEXTAREA';
                if (e.key === '/' && !typing) {
                    e.preventDefault();
                    open();
                } else if (e.key === 'Escape' && backdrop.classList.contains('show')) {
                    close();
                }
            });

            backdrop.addEventListener('click', (e) => {
                if (e.target === backdrop) close();
            });

            input.addEventListener('input', async () => {
                const all = await ensureItems();
                const q = input.value.trim().toLowerCase();
                const filtered = q ? all.filter((it) => it.title.toLowerCase().includes(q)) : all;
                activeIndex = 0;
                render(filtered);
            });

            input.addEventListener('keydown', (e) => {
                const rows = Array.from(list.querySelectorAll('.cmdk-item'));
                if (e.key === 'ArrowDown') {
                    e.preventDefault();
                    activeIndex = Math.min(activeIndex + 1, rows.length - 1);
                    rows.forEach((r, i) => (r.dataset.active = i === activeIndex ? 'true' : 'false'));
                    rows[activeIndex]?.scrollIntoView({ block: 'nearest' });
                } else if (e.key === 'ArrowUp') {
                    e.preventDefault();
                    activeIndex = Math.max(activeIndex - 1, 0);
                    rows.forEach((r, i) => (r.dataset.active = i === activeIndex ? 'true' : 'false'));
                    rows[activeIndex]?.scrollIntoView({ block: 'nearest' });
                } else if (e.key === 'Enter') {
                    rows[activeIndex]?.click();
                }
            });
        })();

        // ---------- KAIDEN_BREAK EASTER EGG: type "kaiden break" ----------
        (function () {
            let typed = '';
            document.addEventListener('keydown', (e) => {
                if (e.key.length !== 1) return;
                typed = (typed + e.key.toLowerCase()).slice(-'kaiden break'.length);
                if (typed === 'kaiden break') {
                    document.getElementById('kaiden-overlay')?.classList.add('show');
                }
            });
        })();

        // ---------- service worker ----------
        if ('serviceWorker' in navigator) {
            window.addEventListener('load', () => {
                navigator.serviceWorker.register('/sw.js').catch(() => {});
            });
        }
        } // end of window.__kehribarInit guard
    </script>
</body>
</html>
