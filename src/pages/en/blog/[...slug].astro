---
import Layout from '../../../layouts/Layout.astro';
import Icon from '../../../components/Icon.astro';
import { getCollection, render } from 'astro:content';
import { translations, langPath } from '../../../lib/i18n';

const lang = 'en' as const;

export async function getStaticPaths() {
  const posts = await getCollection('blog', (p) => p.id.startsWith('en/'));
  return posts.map((post) => ({
    params: { slug: post.id.slice('en/'.length).replace(/\.md$/, '') },
    props: { post },
  }));
}

const { post } = Astro.props;
const dict = translations[lang];
const { Content } = await render(post);
const title = post.data.title ?? post.id.split('/').pop()?.replace(/\.md$/, '') ?? post.id;
---

<Layout title={`${title} - Kehribar`} description={post.data.description} lang={lang} activePage="blog">
    <section>
        <a href={langPath(lang, '/blog')} class="back-link">
            <Icon name="arrow-left" class="icon" /> {dict['back']}
        </a>
        <div class="markdown-content">
            <h1>{title}</h1>
            <Content />
        </div>
    </section>
</Layout>
