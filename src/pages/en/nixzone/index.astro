---
import Layout from '../../../layouts/Layout.astro';
import Icon from '../../../components/Icon.astro';
import { getCollection } from 'astro:content';
import { langPath } from '../../../lib/i18n';

const lang = 'en' as const;

const allPosts = await getCollection('nixzone');
const posts = allPosts
  .filter((p) => p.id.startsWith(`${lang}/`))
  .map((p) => ({
    slug: p.id.slice(lang.length + 1).replace(/\.md$/, ''),
    title: p.data.title ?? p.id.split('/').pop()?.replace(/\.md$/, '') ?? p.id,
    date: p.data.date,
  }))
  .sort((a, b) => (b.date?.getTime() ?? 0) - (a.date?.getTime() ?? 0));
---

<Layout title="NixZONE — Kehribar" lang={lang} activePage="nixzone">
    <div class="hero">
        <span class="eyebrow">/etc/nixos</span>
        <h1>NixZONE</h1>
        <p class="bio">Setup details, desktop rices, and configuration notes.</p>
    </div>

    <div class="section-head">
        <h2>posts</h2>
        <span class="count">{posts.length}</span>
    </div>

    <div class="search-box" id="nix-search-box">
        <Icon name="magnifying-glass" class="icon search-icon" />
        <input type="text" id="nix-search" placeholder="Search posts...">
        <button class="search-clear" id="nix-search-clear" aria-label="clear"><Icon name="xmark" class="icon" /></button>
    </div>

    {posts.length === 0 ? (
        <p class="empty-state">No posts yet — coming soon.</p>
    ) : (
        <div class="ledger" id="nixzone-list">
            {posts.map((post) => (
                <a href={langPath(lang, `/nixzone/${post.slug}`)} class="ledger-row" data-search={post.title.toLowerCase()}>
                    <span class="idx">{post.date ? post.date.toISOString().slice(0, 10) : '—'}</span>
                    <div class="body">
                        <div class="title">{post.title} <Icon name="arrow-left" class="icon arrow" style="transform:rotate(180deg);" /></div>
                    </div>
                </a>
            ))}
        </div>
    )}

    <script>
        document.addEventListener('astro:page-load', () => {
            const input = document.getElementById('nix-search') as HTMLInputElement | null;
            const clearBtn = document.getElementById('nix-search-clear');
            const items = document.querySelectorAll('#nixzone-list .ledger-row');
            if (!input) return;

            function applyFilter() {
                const q = (input?.value ?? '').trim().toLowerCase();
                items.forEach((el) => {
                    const match = (el.getAttribute('data-search') ?? '').includes(q);
                    (el as HTMLElement).style.display = match ? '' : 'none';
                });
            }
            input.addEventListener('input', applyFilter);
            clearBtn?.addEventListener('click', () => { input.value = ''; applyFilter(); });
        });
    </script>
</Layout>
