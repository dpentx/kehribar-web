---
import Layout from '../../../layouts/Layout.astro';
import { loadContributions } from '../../../lib/contributions';
import { translations } from '../../../lib/i18n';

const lang = 'en' as const;
const dict = translations[lang];

const entries = await loadContributions();
---

<Layout title="Contributions - Kehribar" lang={lang} activePage="contributions">
    <section id="contributions" class="section active">
        <div style="text-align:center;margin-bottom:1.5rem;">
            <h2 style="color:var(--green);margin-bottom:0.5rem;">{dict['contributions-intro-title']}</h2>
            <p style="color:var(--text-dim);font-size:0.9rem;">{dict['contributions-intro-text']}</p>
        </div>

        {entries.length === 0 ? (
            <p style="color:var(--text-dim);text-align:center;padding:2rem;">{dict['no-content']}</p>
        ) : (
            <div id="contributions-grid" class="contributions-grid">
                {entries.map((entry) => {
                    const desc = lang === 'en' ? (entry.desc_en || entry.desc) : (entry.desc || entry.desc_en);
                    const typeKey = `contribution-type-${entry.type}` as keyof typeof dict;
                    const typeBadge = (dict as Record<string, string>)[typeKey] || entry.type || '';
                    return (
                        <a class="contribution-card" href={entry.url || '#'} target="_blank" rel="noopener noreferrer">
                            <div class="contribution-header">
                                {entry.icon ? (
                                    <img
                                        class="contribution-icon"
                                        loading="lazy"
                                        decoding="async"
                                        src={`/${entry.icon}`}
                                        alt={entry._name}
                                        onerror="this.outerHTML='<div class=\'contribution-icon-placeholder\'><i class=\'fas fa-puzzle-piece\'></i></div>'"
                                    />
                                ) : (
                                    <div class="contribution-icon-placeholder"><i class="fas fa-puzzle-piece"></i></div>
                                )}
                                <span class="contribution-name">{entry._name}</span>
                            </div>
                            {desc && <p class="contribution-desc">{desc}</p>}
                            {typeBadge && <span class="contribution-badge">{typeBadge}</span>}
                        </a>
                    );
                })}
            </div>
        )}
    </section>
</Layout>
