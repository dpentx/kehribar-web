---
import Layout from '../../../layouts/Layout.astro';
import { getCollection, render } from 'astro:content';
import { translations, type Lang } from '../../../lib/i18n';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post) => {
    const [lang, ...rest] = post.id.split('/');
    return {
      params: { lang, slug: rest.join('/').replace(/\.md$/, '') },
      props: { post },
    };
  });
}

const { post } = Astro.props;
const lang = (Astro.params.lang as Lang) === 'en' ? 'en' : 'tr';
const dict = translations[lang];
const { Content } = await render(post);
const title = post.data.title ?? post.id.split('/').pop()?.replace(/\.md$/, '') ?? post.id;
---

<Layout title={`${title} - Kehribar`} description={post.data.description} lang={lang} activePage="blog">
    <section class="section active">
        <a href={`/blog?lang=${lang}`} style="color:var(--green);text-decoration:none;display:inline-flex;align-items:center;gap:0.4rem;margin-bottom:1rem;">
            <i class="fas fa-arrow-left"></i> {dict['back']}
        </a>
        <div class="markdown-content">
            <h1 style="color:var(--green);margin-bottom:1rem;">{title}</h1>
            <Content />
        </div>
    </section>
</Layout>
