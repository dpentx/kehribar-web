---
import Layout from '../../layouts/Layout.astro';
import { getCollection, render } from 'astro:content';
import { translations, langPath } from '../../lib/i18n';

const lang = 'tr' as const;

export async function getStaticPaths() {
  const posts = await getCollection('blog', (p) => p.id.startsWith('tr/'));
  return posts.map((post) => ({
    params: { slug: post.id.slice('tr/'.length).replace(/\.md$/, '') },
    props: { post },
  }));
}

const { post } = Astro.props;
const dict = translations[lang];
const { Content } = await render(post);
const title = post.data.title ?? post.id.split('/').pop()?.replace(/\.md$/, '') ?? post.id;
---

<Layout title={`${title} - Kehribar`} description={post.data.description} lang={lang} activePage="blog">
    <section class="section active">
        <a href={langPath(lang, '/blog')} style="color:var(--green);text-decoration:none;display:inline-flex;align-items:center;gap:0.4rem;margin-bottom:1rem;">
            <i class="fas fa-arrow-left"></i> {dict['back']}
        </a>
        <div class="markdown-content">
            <h1 style="color:var(--green);margin-bottom:1rem;">{title}</h1>
            <Content />
        </div>
    </section>
</Layout>
