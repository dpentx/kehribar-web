---
import Layout from '../../layouts/Layout.astro';
import Icon from '../../components/Icon.astro';
import { fetchGithubStats, attachRepoDescriptions } from '../../lib/github';

const lang = 'tr' as const;

const stats = await fetchGithubStats();
const nonForkRepos = stats.repos.filter((r) => !r.fork).sort((a, b) => b.stargazers_count - a.stargazers_count);
const repos = await attachRepoDescriptions(nonForkRepos, lang);
---

<Layout title="Projeler — Kehribar" lang={lang} activePage="projects">
    <div class="section-head">
        <h2>projeler</h2>
        <span class="count">{repos.length}</span>
    </div>

    {repos.length === 0 ? (
        <p class="empty-state">İçerik bulunamadı.</p>
    ) : (
        <div class="ledger">
            {repos.map((repo) => {
                const desc = repo.customDesc || repo.description;
                return (
                    <a href={repo.html_url} target="_blank" rel="noopener noreferrer" class="ledger-row">
                        <span class="idx">{repo.language ?? '—'}</span>
                        <div class="body">
                            <div class="title">
                                {repo.name}
                                <Icon name="arrow-left" class="icon arrow" style="transform:rotate(180deg);" />
                            </div>
                            {desc && <div class="desc">{desc}</div>}
                        </div>
                        {repo.stargazers_count > 0 && (
                            <span class="meta"><Icon name="star" class="icon" style="color:var(--amber);" /> {repo.stargazers_count}</span>
                        )}
                    </a>
                );
            })}
        </div>
    )}
</Layout>
