---
import Layout from '../layouts/Layout.astro';
import { fetchGithubStats } from '../lib/github';
import { loadNow, nowText } from '../lib/now';
import { getCollection } from 'astro:content';

const lang = 'tr' as const;

const [stats, blogPosts, now] = await Promise.all([fetchGithubStats(), getCollection('blog'), loadNow()]);
const postCount = blogPosts.filter((p) => p.id.startsWith(`${lang}/`)).length;
---

<Layout title="Kehribar — dpentx" lang={lang} activePage="home">
    <div class="hero">
        <span class="eyebrow">~/kehribar</span>
        <h1>NixOS kullanan, çeviri yapan biri.</h1>
        <p class="bio">Açık kaynak projelere katkı sağlıyorum, masaüstümü fazlasıyla özelleştiriyorum ve boş zamanlarımda İngilizce'den Türkçe'ye çeviri yapıyorum.</p>
        <p class="now-line"><span class="amber">▸ şu an:</span> {nowText(now, lang)}</p>
        <div class="nix-block">{"{"}
  <span class="key">name</span> = <span class="str">"kehribar"</span>;
  <span class="key">os</span> = <span class="str">"NixOS"</span>;
  <span class="key">compositor</span> = <span class="str">"niri"</span>;
  <span class="key">translates</span> = [ <span class="str">"en"</span> <span class="str">"tr"</span> ];
{"}"}<span class="nix-cursor"></span></div>
    </div>

    <div class="stat-row">
        <div class="stat-cell">
            <span class="n">{postCount}</span>
            <span class="l">blog yazısı</span>
        </div>
        <div class="stat-cell">
            <span class="n">{stats.repoCount}</span>
            <span class="l">repo</span>
        </div>
        <div class="stat-cell">
            <span class="n">{stats.starCount}</span>
            <span class="l">yıldız</span>
        </div>
    </div>

    <div style="text-align: center;">
        <p style="color: var(--ink-dim); font-family: var(--mono); font-size: 0.75rem; margin-bottom: 0.5rem;">visitor counter</p>
        <img
            src="https://count.getloli.com/@dpentx?name=everforest&theme=rule34&padding=7&offset=0&align=top&scale=1&pixelated=1&darkmode=1"
            alt="visitor count"
            loading="lazy"
            width="140"
            height="35"
            style="border-radius:8px;height:auto;"
        >
    </div>
</Layout>
